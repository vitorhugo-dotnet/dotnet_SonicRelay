COMPOSE_PROJECT_NAME=sonicrelay
COMPOSE_PROFILES=prod
ASPNETCORE_ENVIRONMENT=Production
API_PUBLIC_BASE_URL=https://sonicrelay-api.hugodotnet.dev
API_IMAGE=ghcr.io/seu-user/sonicrelay-api:latest
POSTGRES_VERSION=17-alpine
POSTGRES_DB=sonicrelay
POSTGRES_USER=sonicrelay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
REDIS_VERSION=7-alpine
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_REQUIRE_CONFIRMED_EMAIL=true
SESSION_CODE_TTL_MINUTES=10
SESSION_MAX_VIEWERS=3
SESSION_IDLE_TIMEOUT_MINUTES=5
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_JOIN_SESSION_PER_MINUTE=10
RATE_LIMIT_CREATE_SESSION_PER_MINUTE=10
# WEBRTC_TURN_HOST's DNS record must be DNS-only (grey cloud in Cloudflare),
# not proxied -- TURN/STUN require direct UDP/TCP reachability. Keep this
# host separate from the API/WSS domain (API_PUBLIC_BASE_URL above), which
# stays Cloudflare-proxied (orange cloud).
WEBRTC_TURN_HOST=sonicrelay-turn.hugodotnet.dev
WEBRTC_TURN_REALM=sonicrelay-turn.hugodotnet.dev
WEBRTC_TURN_SECRET=CHANGE_ME_STRONG_TURN_SECRET
WEBRTC_TURN_TTL_SECONDS=3600
WEBRTC_ENABLE_GOOGLE_STUN_FALLBACK=false
COTURN_VERSION=latest
